// LocalIDs match the order of object_events in map.json (1-indexed)
const LOCALID_HELIX_FOSSIL = 1
const LOCALID_DOME_FOSSIL  = 2
const LOCALID_TABITHA      = 3
const LOCALID_COURTNEY     = 4
const LOCALID_GRUNT        = 5

mapscripts Rusturf_MagmaCave_Final_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (!flag(FLAG_MAGMA_ADMINS_RUSTURF_DEFEATED)) {
            setflag(FLAG_HIDE_RUSTURF_MAGMA_CAVE_FINAL_TABITHA)
            setflag(FLAG_HIDE_RUSTURF_MAGMA_CAVE_FINAL_COURTNEY)
            setflag(FLAG_HIDE_RUSTURF_MAGMA_CAVE_FINAL_GRUNT)
        }
    }
}

// ============================================================
// HELIX FOSSIL (x10, y17)
// Player can interact from x10,y16 (facing down) or x11,y17 (facing left)
// ============================================================

script Rusturf_MagmaCave_Final_EventScript_HelixFossil {
    goto_if_set(FLAG_MAGMA_ADMINS_RUSTURF_DEFEATED, Rusturf_MagmaCave_Final_EventScript_FossilGone)
    goto_if_set(FLAG_CHOSE_DOME_FOSSIL, Rusturf_MagmaCave_Final_EventScript_FossilGone)
    lock
    copyvar(VAR_TEMP_0, VAR_FACING)
    msgbox(Rusturf_MagmaCave_Final_Text_HelixFossilDesc, MSGBOX_YESNO)
    goto_if_eq(VAR_RESULT, NO, Rusturf_MagmaCave_Final_EventScript_FossilDecline)
    setvar(VAR_TEMP_1, 1)
    goto_if_eq(VAR_TEMP_0, DIR_SOUTH, Rusturf_MagmaCave_Final_EventScript_HelixApproach_Down)
    goto(Rusturf_MagmaCave_Final_EventScript_HelixApproach_Side)
    end
}

// ============================================================
// DOME FOSSIL (x12, y17)
// Player can interact from x12,y16 (facing down) or x11,y17 (facing right)
// ============================================================

script Rusturf_MagmaCave_Final_EventScript_DomeFossil {
    goto_if_set(FLAG_MAGMA_ADMINS_RUSTURF_DEFEATED, Rusturf_MagmaCave_Final_EventScript_FossilGone)
    goto_if_set(FLAG_CHOSE_HELIX_FOSSIL, Rusturf_MagmaCave_Final_EventScript_FossilGone)
    lock
    copyvar(VAR_TEMP_0, VAR_FACING)
    msgbox(Rusturf_MagmaCave_Final_Text_DomeFossilDesc, MSGBOX_YESNO)
    goto_if_eq(VAR_RESULT, NO, Rusturf_MagmaCave_Final_EventScript_FossilDecline)
    setvar(VAR_TEMP_1, 2)
    goto_if_eq(VAR_TEMP_0, DIR_SOUTH, Rusturf_MagmaCave_Final_EventScript_DomeApproach_Down)
    goto(Rusturf_MagmaCave_Final_EventScript_DomeApproach_Side)
    end
}

// ============================================================
// TRIGGER TILES - NOT ENOUGH MONS CHECK (y16 row)
// Three tiles: x10,y16 (TileA), x11,y16 (TileB), x12,y16 (TileC)
// If player has < 2 alive non-egg mons, admins flank from the
// two unoccupied tiles, deliver the warning, fade to black,
// then reposition player 3 tiles north (y13).
// ============================================================

// Tile A: player at x10,y16 → admins move to x11,y16 and x12,y16
script Rusturf_MagmaCave_Final_EventScript_TriggerTileA {
    goto_if_set(FLAG_MAGMA_ADMINS_RUSTURF_DEFEATED, Rusturf_MagmaCave_Final_EventScript_TriggerTileEnd)
    specialvar(VAR_RESULT, CountPartyAliveNonEggMons)
    if (var(VAR_RESULT) >= 2) {
        release
        end
    }
    lockall
    addobject(LOCALID_TABITHA)
    addobject(LOCALID_COURTNEY)
    applymovement(LOCALID_TABITHA, Rusturf_MagmaCave_Final_Movement_Tabitha_NotEnough_TileA)
    applymovement(LOCALID_COURTNEY, Rusturf_MagmaCave_Final_Movement_Courtney_NotEnough_TileAorB)
    waitmovement(0)
    msgbox(Rusturf_MagmaCave_Final_Text_TabithaNotEnoughMons, MSGBOX_DEFAULT)
    closemessage()
    fadescreen(FADE_TO_BLACK)
    removeobject(LOCALID_TABITHA)
    removeobject(LOCALID_COURTNEY)
    applymovement(OBJ_EVENT_ID_PLAYER, Rusturf_MagmaCave_Final_Movement_Player_NotEnoughPushback)
    waitmovement(0)
    fadescreen(FADE_FROM_BLACK)
    releaseall
    end
}

// Tile B: player at x11,y16 → admins move to x10,y16 and x12,y16
script Rusturf_MagmaCave_Final_EventScript_TriggerTileB {
    goto_if_set(FLAG_MAGMA_ADMINS_RUSTURF_DEFEATED, Rusturf_MagmaCave_Final_EventScript_TriggerTileEnd)
    specialvar(VAR_RESULT, CountPartyAliveNonEggMons)
    if (var(VAR_RESULT) >= 2) {
        release
        end
    }
    lockall
    addobject(LOCALID_TABITHA)
    addobject(LOCALID_COURTNEY)
    applymovement(LOCALID_TABITHA, Rusturf_MagmaCave_Final_Movement_Tabitha_NotEnough_TileBorC)
    applymovement(LOCALID_COURTNEY, Rusturf_MagmaCave_Final_Movement_Courtney_NotEnough_TileAorB)
    waitmovement(0)
    msgbox(Rusturf_MagmaCave_Final_Text_TabithaNotEnoughMons, MSGBOX_DEFAULT)
    closemessage()
    fadescreen(FADE_TO_BLACK)
    removeobject(LOCALID_TABITHA)
    removeobject(LOCALID_COURTNEY)
    applymovement(OBJ_EVENT_ID_PLAYER, Rusturf_MagmaCave_Final_Movement_Player_NotEnoughPushback)
    waitmovement(0)
    fadescreen(FADE_FROM_BLACK)
    releaseall
    end
}

// Tile C: player at x12,y16 → admins move to x10,y16 and x11,y16
script Rusturf_MagmaCave_Final_EventScript_TriggerTileC {
    goto_if_set(FLAG_MAGMA_ADMINS_RUSTURF_DEFEATED, Rusturf_MagmaCave_Final_EventScript_TriggerTileEnd)
    specialvar(VAR_RESULT, CountPartyAliveNonEggMons)
    if (var(VAR_RESULT) >= 2) {
        release
        end
    }
    lockall
    addobject(LOCALID_TABITHA)
    addobject(LOCALID_COURTNEY)
    applymovement(LOCALID_TABITHA, Rusturf_MagmaCave_Final_Movement_Tabitha_NotEnough_TileBorC)
    applymovement(LOCALID_COURTNEY, Rusturf_MagmaCave_Final_Movement_Courtney_NotEnough_TileC)
    waitmovement(0)
    msgbox(Rusturf_MagmaCave_Final_Text_TabithaNotEnoughMons, MSGBOX_DEFAULT)
    closemessage()
    fadescreen(FADE_TO_BLACK)
    removeobject(LOCALID_TABITHA)
    removeobject(LOCALID_COURTNEY)
    applymovement(OBJ_EVENT_ID_PLAYER, Rusturf_MagmaCave_Final_Movement_Player_NotEnoughPushback)
    waitmovement(0)
    fadescreen(FADE_FROM_BLACK)
    releaseall
    end
}

script Rusturf_MagmaCave_Final_EventScript_TriggerTileEnd {
    release
    end
}

// ============================================================
// SHARED UTILITY SCRIPTS
// ============================================================

script Rusturf_MagmaCave_Final_EventScript_FossilDecline {
    msgbox(Rusturf_MagmaCave_Final_Text_FossilDecline, MSGBOX_DEFAULT)
    release
    end
}

script Rusturf_MagmaCave_Final_EventScript_FossilGone {
    end
}

// ============================================================
// ADMIN APPROACH - HELIX FOSSIL CHOSEN
// ============================================================

// Player was at x10,y16 facing down
// Tabitha: x10,y8 → x10,y15 (7 down, face down)
// Courtney: x11,y8 → x11,y16 (8 down, face left)
script Rusturf_MagmaCave_Final_EventScript_HelixApproach_Down {
    addobject(LOCALID_TABITHA)
    addobject(LOCALID_COURTNEY)
    applymovement(LOCALID_TABITHA, Rusturf_MagmaCave_Final_Movement_Tabitha_HelixDown)
    applymovement(LOCALID_COURTNEY, Rusturf_MagmaCave_Final_Movement_Courtney_HelixDown)
    waitmovement(0)
    goto(Rusturf_MagmaCave_Final_EventScript_DoAdminBattle)
    end
}

// Player was at x11,y17 facing left
// Tabitha first: x10,y8 → x10,y16 (8 down) → x11,y16 (1 right, face down)
// Then Courtney: x11,y8 → x10,y8 (1 left) → x10,y16 (8 down, face down)
script Rusturf_MagmaCave_Final_EventScript_HelixApproach_Side {
    addobject(LOCALID_TABITHA)
    addobject(LOCALID_COURTNEY)
    applymovement(LOCALID_TABITHA, Rusturf_MagmaCave_Final_Movement_Tabitha_HelixSide)
    waitmovement(0)
    applymovement(LOCALID_COURTNEY, Rusturf_MagmaCave_Final_Movement_Courtney_HelixSide)
    waitmovement(0)
    goto(Rusturf_MagmaCave_Final_EventScript_DoAdminBattle)
    end
}

// ============================================================
// ADMIN APPROACH - DOME FOSSIL CHOSEN
// ============================================================

// Player was at x12,y16 facing down
// Courtney first: x11,y8 → x11,y16 (8 down, face right)
// Then Tabitha: x10,y8 → x10,y15 (7 down) → x12,y15 (2 right, face down)
script Rusturf_MagmaCave_Final_EventScript_DomeApproach_Down {
    addobject(LOCALID_TABITHA)
    addobject(LOCALID_COURTNEY)
    applymovement(LOCALID_COURTNEY, Rusturf_MagmaCave_Final_Movement_Courtney_DomeDown)
    waitmovement(0)
    applymovement(LOCALID_TABITHA, Rusturf_MagmaCave_Final_Movement_Tabitha_DomeDown)
    waitmovement(0)
    goto(Rusturf_MagmaCave_Final_EventScript_DoAdminBattle)
    end
}

// Player was at x11,y17 facing right
// Courtney first: x11,y8 → x12,y8 (1 right) → x12,y17 (8 down, face down)
// Then Tabitha: x10,y8 → x11,y8 (1 right) → x11,y16 (8 down, face down)
script Rusturf_MagmaCave_Final_EventScript_DomeApproach_Side {
    addobject(LOCALID_TABITHA)
    addobject(LOCALID_COURTNEY)
    applymovement(LOCALID_COURTNEY, Rusturf_MagmaCave_Final_Movement_Courtney_DomeSide)
    waitmovement(0)
    applymovement(LOCALID_TABITHA, Rusturf_MagmaCave_Final_Movement_Tabitha_DomeSide)
    waitmovement(0)
    goto(Rusturf_MagmaCave_Final_EventScript_DoAdminBattle)
    end
}

// ============================================================
// DOUBLE BATTLE
// ============================================================

script Rusturf_MagmaCave_Final_EventScript_DoAdminBattle {
    msgbox(Rusturf_MagmaCave_Final_Text_AdminsApproach, MSGBOX_DEFAULT)
    trainerbattle_double(TRAINER_TABITHA_AND_COURTNEY_RUSTURF,
        Rusturf_MagmaCave_Final_Text_TabithaIntro,
        Rusturf_MagmaCave_Final_Text_TabithaDefeat,
        Rusturf_MagmaCave_Final_Text_TabithaNotEnoughMons,
        Rusturf_MagmaCave_Final_EventScript_PostBattle)
    release
    end
}

// ============================================================
// POST-BATTLE: GRUNT STEALS REMAINING FOSSIL
// ============================================================

script Rusturf_MagmaCave_Final_EventScript_PostBattle {
    goto_if_eq(VAR_TEMP_1, 1, Rusturf_MagmaCave_Final_EventScript_GiveHelixFossil)
    goto(Rusturf_MagmaCave_Final_EventScript_GiveDomeFossil)
    end
}

// Give chosen fossil to player on victory, then trigger grunt sequence
script Rusturf_MagmaCave_Final_EventScript_GiveHelixFossil {
    giveitem(ITEM_HELIX_FOSSIL)
    goto_if_eq(VAR_RESULT, FALSE, Rusturf_MagmaCave_Final_EventScript_PostBattleBagFull)
    setflag(FLAG_CHOSE_HELIX_FOSSIL)
    removeobject(LOCALID_HELIX_FOSSIL)
    goto(Rusturf_MagmaCave_Final_EventScript_GruntStealDome)
    end
}

script Rusturf_MagmaCave_Final_EventScript_GiveDomeFossil {
    giveitem(ITEM_DOME_FOSSIL)
    goto_if_eq(VAR_RESULT, FALSE, Rusturf_MagmaCave_Final_EventScript_PostBattleBagFull)
    setflag(FLAG_CHOSE_DOME_FOSSIL)
    removeobject(LOCALID_DOME_FOSSIL)
    goto(Rusturf_MagmaCave_Final_EventScript_GruntStealHelix)
    end
}

// Bag+PC both full after winning: set all flags, remove all objects, end cleanly
script Rusturf_MagmaCave_Final_EventScript_PostBattleBagFull {
    setflag(FLAG_CHOSE_HELIX_FOSSIL)
    setflag(FLAG_CHOSE_DOME_FOSSIL)
    setflag(FLAG_FOSSIL_STOLEN_BY_GRUNT)
    setflag(FLAG_MAGMA_ADMINS_RUSTURF_DEFEATED)
    setvar(VAR_ROXANNE_QUEST_STATE, 4)
    setflag(FLAG_ROXANNE_QUEST_COMPLETE)
    removeobject(LOCALID_HELIX_FOSSIL)
    removeobject(LOCALID_DOME_FOSSIL)
    removeobject(LOCALID_TABITHA)
    removeobject(LOCALID_COURTNEY)
    removeobject(LOCALID_GRUNT)
    msgbox(Rusturf_MagmaCave_Final_Text_PostBattleBagFull, MSGBOX_DEFAULT)
    release
    end
}

// Player picked Helix (via victory) - grunt steals Dome (x12,y17)
// Grunt: x11,y7 → walk down 10 → look right 1
script Rusturf_MagmaCave_Final_EventScript_GruntStealDome {
    addobject(LOCALID_GRUNT)
    applymovement(LOCALID_GRUNT, Rusturf_MagmaCave_Final_Movement_Grunt_ToDome)
    waitmovement(0)
    msgbox(Rusturf_MagmaCave_Final_Text_GruntStealDome, MSGBOX_DEFAULT)
    closemessage()
    delay(30)
    removeobject(LOCALID_DOME_FOSSIL)
    setflag(FLAG_CHOSE_DOME_FOSSIL)
    setflag(FLAG_FOSSIL_STOLEN_BY_GRUNT)
    goto(Rusturf_MagmaCave_Final_EventScript_AllExit)
    end
}

// Player picked Dome - grunt steals Helix (x10,y17)
// Grunt: x11,y7 → walk down 10 → look left 1
script Rusturf_MagmaCave_Final_EventScript_GruntStealHelix {
    addobject(LOCALID_GRUNT)
    applymovement(LOCALID_GRUNT, Rusturf_MagmaCave_Final_Movement_Grunt_ToHelix)
    waitmovement(0)
    msgbox(Rusturf_MagmaCave_Final_Text_GruntStealHelix, MSGBOX_DEFAULT)
    closemessage()
    delay(30)
    removeobject(LOCALID_HELIX_FOSSIL)
    setflag(FLAG_CHOSE_HELIX_FOSSIL)
    setflag(FLAG_FOSSIL_STOLEN_BY_GRUNT)
    goto(Rusturf_MagmaCave_Final_EventScript_AllExit)
    end
}

// All three NPCs deliver a farewell, walk up off-screen, then are removed and the event flag is set
script Rusturf_MagmaCave_Final_EventScript_AllExit {
    msgbox(Rusturf_MagmaCave_Final_Text_TabithaFarewell, MSGBOX_DEFAULT)
    closemessage()
    applymovement(LOCALID_TABITHA, Rusturf_MagmaCave_Final_Movement_ExitUp)
    applymovement(LOCALID_COURTNEY, Rusturf_MagmaCave_Final_Movement_ExitUp)
    applymovement(LOCALID_GRUNT, Rusturf_MagmaCave_Final_Movement_ExitUp)
    waitmovement(0)
    removeobject(LOCALID_TABITHA)
    removeobject(LOCALID_COURTNEY)
    removeobject(LOCALID_GRUNT)
    setflag(FLAG_MAGMA_ADMINS_RUSTURF_DEFEATED)
    setflag(FLAG_ROXANNE_QUEST_COMPLETE)
    setvar(VAR_ROXANNE_QUEST_STATE, 4)
    release
    end
}

// ============================================================
// MOVEMENT SCRIPTS - NOT ENOUGH MONS TRIGGER FLANKING
// ============================================================

// Tile A (player at x10,y16): Tabitha x10,y8 → x11,y16 (face left toward player)
movement Rusturf_MagmaCave_Final_Movement_Tabitha_NotEnough_TileA {
    walk_fast_right
    walk_fast_down * 8
    face_left
    step_end
}

// Tile B/C (player at x11/x12,y16): Tabitha x10,y8 → x10,y16 (face right toward player)
movement Rusturf_MagmaCave_Final_Movement_Tabitha_NotEnough_TileBorC {
    walk_fast_down * 8
    face_right
    step_end
}

// Tile A/B (player at x10/x11,y16): Courtney x11,y8 → x12,y16 (face left toward player)
movement Rusturf_MagmaCave_Final_Movement_Courtney_NotEnough_TileAorB {
    walk_fast_right
    walk_fast_down * 8
    face_left
    step_end
}

// Tile C (player at x12,y16): Courtney x11,y8 → x11,y16 (face right toward player)
movement Rusturf_MagmaCave_Final_Movement_Courtney_NotEnough_TileC {
    walk_fast_down * 8
    face_right
    step_end
}

// Player pushed back 3 tiles north (y16 → y13), executed while screen is faded
movement Rusturf_MagmaCave_Final_Movement_Player_NotEnoughPushback {
    walk_up * 3
    step_end
}

// ============================================================
// MOVEMENT SCRIPTS
// ============================================================

// Helix fossil chosen, player at x10,y16 facing down
movement Rusturf_MagmaCave_Final_Movement_Tabitha_HelixDown {
    walk_fast_down * 7
    face_down
    step_end
}

movement Rusturf_MagmaCave_Final_Movement_Courtney_HelixDown {
    walk_fast_down * 8
    face_left
    step_end
}

// Helix fossil chosen, player at x11,y17 facing left
movement Rusturf_MagmaCave_Final_Movement_Tabitha_HelixSide {
    walk_fast_down * 8
    walk_fast_right
    face_down
    step_end
}

movement Rusturf_MagmaCave_Final_Movement_Courtney_HelixSide {
    walk_fast_left
    walk_fast_down * 8
    face_down
    step_end
}

// Dome fossil chosen, player at x12,y16 facing down
movement Rusturf_MagmaCave_Final_Movement_Courtney_DomeDown {
    walk_fast_down * 8
    face_right
    step_end
}

movement Rusturf_MagmaCave_Final_Movement_Tabitha_DomeDown {
    walk_fast_down * 7
    walk_fast_right * 2
    face_down
    step_end
}

// Dome fossil chosen, player at x11,y17 facing right
movement Rusturf_MagmaCave_Final_Movement_Courtney_DomeSide {
    walk_fast_right
    walk_fast_down * 8
    face_down
    step_end
}

movement Rusturf_MagmaCave_Final_Movement_Tabitha_DomeSide {
    walk_fast_right
    walk_fast_down * 8
    face_down
    step_end
}

// Grunt movements (starts at x11,y7, ends at x12, y16)
movement Rusturf_MagmaCave_Final_Movement_Grunt_ToDome {
    walk_fast_down * 7
    walk_fast_right * 1
    walk_fast_down * 2
    step_end
}

movement Rusturf_MagmaCave_Final_Movement_Grunt_ToHelix {
    walk_fast_down * 7
    walk_fast_left * 1
    walk_fast_down * 2
    step_end
}

// Shared exit - walk up off-screen
movement Rusturf_MagmaCave_Final_Movement_ExitUp {
    walk_fast_up * 12
    step_end
}

// ============================================================
// TEXT
// ============================================================

text Rusturf_MagmaCave_Final_Text_HelixFossilDesc {
    format("It's the Helix Fossil!\nWould you like to take it?")
}

text Rusturf_MagmaCave_Final_Text_DomeFossilDesc {
    format("It's the Dome Fossil!\nWould you like to take it?")
}

text Rusturf_MagmaCave_Final_Text_FossilDecline {
    format("You decide to leave the fossil where it is for now.")
}

text Rusturf_MagmaCave_Final_Text_NotEnoughMons {
    format("TABITHA: Hmph. You don't even have enough POKeMON\nto face us both.\pCome back when you're a real trainer.")
}

text Rusturf_MagmaCave_Final_Text_AdminsApproach {
    format("TABITHA: I'm impressed you made it this far. We may not have found the LEGENDARY Pokémon we were looking for in this cave, but these fossils are a priceless consolation prize. They belong to Team MAGMA, and we're not just going to let you walk away with one!\pCOURTNEY: Yeah! You want it? You'll have to go through us!")
}

text Rusturf_MagmaCave_Final_Text_TabithaIntro {
    format("TABITHA: You want to keep it that badly?\pWe'll show you that crossing Team MAGMA is a huge mistake!")
}

text Rusturf_MagmaCave_Final_Text_TabithaDefeat {
    format("TABITHA: Tch...\nYou're stronger than you look. But we kept you busy enough to steal the other fossil, so it's not like you win!")
}

text Rusturf_MagmaCave_Final_Text_TabithaNotEnoughMons {
    format("TABITHA: You don't even\nhave enough Pokémon\lto face us both!")
}

text Rusturf_MagmaCave_Final_Text_GruntStealDome {
    format("GRUNT: Heh! I'll be taking that Dome Fossil!")
}

text Rusturf_MagmaCave_Final_Text_GruntStealHelix {
    format("GRUNT: Heh! I'll be taking that Helix Fossil!")
}

text Rusturf_MagmaCave_Final_Text_TabithaFarewell {
    format("TABITHA: Don't look so smug.\pTeam MAGMA will put that fossil\nto good use. Let's move out!")
}

text Rusturf_MagmaCave_Final_Text_PostBattleBagFull {
    format("Your BAG and PC are both full!\pTeam MAGMA grabbed the fossil and\nfled while you scrambled.\pMake room and try again next time...")
}

